# Gemini API key. Required for `retrokit assets *` commands.
GEMINI_API_KEY=your_api_key_here

# Optional: override the Gemini API endpoint.
# GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-3-pro-image-preview:generateContent

# Optional: override reference and output directories.
# RETRO_INPUT_DIR=.input
# RETRO_OUTPUT_DIR=output

# Optional: control PNG quantization.
# RETRO_QUANTIZE=true
# RETRO_QUANTIZE_QUALITY=65-80
